{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (FastAPI + HTMX)",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "web.app:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Focus Guard (daemon)",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["focus_guard_service.py"],
      "port": 9000
    }
  ]
}
