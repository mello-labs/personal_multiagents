# =============================================================================
# .env.example — Copie para .env e preencha os valores
# No Railway: configure via Dashboard → Variables (NÃO versione o .env)
# =============================================================================

# --- LLM (OpenAI público) ---------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# --- LLM local opcional (Docker Model Runner, dev local apenas) -------------
# LOCAL_MODEL_ENABLED=false
# LOCAL_MODEL_NAME=docker.io/ai/gemma3:4B-F16

# --- Notion — NEØ Command Center --------------------------------------------
NOTION_TOKEN=secret_...
# IDs dos 5 databases do Command Center (workspace neoflw)
NOTION_DB_PROJETOS=
NOTION_DB_TAREFAS=
NOTION_DB_DECISOES=
NOTION_DB_WORKLOG=
NOTION_DB_INTEGRATIONS=

# Legado multiagents (pode reaproveitar ou deixar vazio)
NOTION_TASKS_DB_ID=
NOTION_AGENDA_DB_ID=
NOTION_SYNC_INTERVAL=5
NOTION_RETROSPECTIVE_PAGE_ID=

# --- Redis (Railway provisiona automaticamente) -----------------------------
# Local:   redis://localhost:6379/0
# Railway: redis://default:PASSWORD@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379/0

# --- Telegram (captura inbound) ---------------------------------------------
TELEGRAM_BOT_TOKEN=
# chat IDs autorizados (comma-separated). Vazio = libera todos (NÃO recomendado)
TELEGRAM_ALLOWED_CHAT_IDS=

# --- GitHub Projects v2 (espelho de tarefas de engenharia) ------------------
# PAT com scopes: project, read:org, repo
GITHUB_TOKEN=
GH_PROJECT_FLOWPAY=1
GH_PROJECT_FLOWOFF=1
GH_PROJECT_NEO=1
GH_PROJECT_FACTORY=1
# Manifests locais para `python main.py github discover` (default macOS)
# NEOMELLO_WORKSPACES_ROOT=/Users/nettomello/neomello
# Selects no DB Command Center "Tarefas & Ações" (se o Notion usar outros nomes)
# GITHUB_NOTION_STATUS_OPEN=📋 Backlog
# GITHUB_NOTION_STATUS_CLOSED=✅ Concluído
# GITHUB_NOTION_PRIORITY_DEFAULT=⚡ Média

# --- Google Calendar (opcional) ---------------------------------------------
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_TOKEN_FILE=./token.json
GOOGLE_CALENDAR_ID=primary

# --- Focus / Life Guard -----------------------------------------------------
FOCUS_CHECK_INTERVAL=15
LIFE_GUARD_ACTIVE_HOUR_START=8
LIFE_GUARD_ACTIVE_HOUR_END=22
LIFE_GUARD_WATER_INTERVAL=90

# --- Notificações Alexa (opcional) ------------------------------------------
VOICE_MONKEY_TOKEN=
VOICE_MONKEY_DEVICE=eco-room
VOICE_MONKEY_VOICE=Ricardo
IFTTT_WEBHOOK_KEY=
IFTTT_ALEXA_EVENT=neo_alert

# --- Logging ---------------------------------------------------------------
LOG_FILE=./logs/agent_system.log
LOG_LEVEL=INFO

# --- Web (Railway seta PORT automaticamente) --------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000
