# =============================================================================
# NΞØ PROTOCOL — MULTIAGENTS KERNEL OS
# =============================================================================
# File: Makefile
# Version: 1.0.0
# License: Proprietary / NΞØ Protocol
# =============================================================================

# -----------------------------------------------------------------------------
# CONFIGURATION & VARIABLES
# -----------------------------------------------------------------------------
SHELL       := /bin/bash
PYTHON      := python3
VENV        := .venv
BIN         := $(VENV)/bin
PIP         := $(BIN)/pip
PY          := $(BIN)/python
UVICORN     := $(BIN)/uvicorn
RUFF        := $(BIN)/ruff
PYTEST      := $(BIN)/pytest
PIP_AUDIT   := $(BIN)/pip-audit

# Metadata
PROJECT_NAME := mypersonal_multiagents
VERSION      := $(shell git describe --tags --always 2>/dev/null || echo "v0.5.1")
LAST_COMMIT  := $(shell git log -1 --format="%h %s" 2>/dev/null || echo "no-commits")

# Colors & Formatting
BOLD   := \033[1m
CYAN   := \033[36m
GREEN  := \033[32m
YELLOW := \033[33m
RED    := \033[31m
RESET  := \033[0m
MAGENTA:= \033[35m

# -----------------------------------------------------------------------------
# DEFAULT GOAL
# -----------------------------------------------------------------------------
.DEFAULT_GOAL := help

# -----------------------------------------------------------------------------
# CORE COMMANDS (NΞØ FLOW)
# -----------------------------------------------------------------------------

.PHONY: help
help: ## Display this help menu with categories
	@echo -e "\n$(BOLD)$(MAGENTA)--- $(PROJECT_NAME) ($(VERSION)) ---$(RESET)"
	@echo -e "$(CYAN)Usage: make <target>$(RESET)\n"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  $(GREEN)%-20s$(RESET) %s\n", $$1, $$2}'
	@echo -e "\n$(YELLOW)NΞØ Protocol:$(RESET) Use 'make commit' for secure delivery.\n"

.PHONY: setup
setup: venv install env-init redis-ready ## Complete bootstrap (venv + deps + .env + redis)
	@echo -e "$(GREEN)✓ System ready. Use 'make dev' to start.$(RESET)"

.PHONY: doctor
doctor: ## Run a full system diagnostic check
	@echo -e "$(CYAN)Checking system health...$(RESET)"
	@$(PY) scripts/diagnose.py || echo -e "$(YELLOW)⚠ Diagnosis script failed, checking basics...$(RESET)"
	@$(PY) -c "import redis; r=redis.Redis(); r.ping(); print('$(GREEN)✓ Redis Connection OK$(RESET)')" || echo -e "$(RED)✗ Redis down$(RESET)"
	@test -f .env && echo -e "$(GREEN)✓ .env exists$(RESET)" || echo -e "$(RED)✗ .env missing$(RESET)"
	@$(PY) --version | awk '{printf "$(GREEN)✓ Python %s$(RESET)\n", $$2}'

# -----------------------------------------------------------------------------
# DEVELOPMENT & RUNTIME
# -----------------------------------------------------------------------------

.PHONY: dev
dev: redis-ready ## Start FastAPI server with hot-reload
	@echo -e "$(CYAN)🚀 Launching Kernel Web UI...$(RESET)"
	@REDIS_URL=$${REDIS_URL:-redis://localhost:6379/0} \
		$(UVICORN) web.app:app --host 127.0.0.1 --port 8000 --reload

.PHONY: guard
guard: redis-ready ## Launch Focus Guard in persistent terminal
	@echo -e "$(CYAN)🛡️ Focus Guard Active...$(RESET)"
	@$(PY) main.py

.PHONY: sync-all
sync-all: redis-ready ## Sync everything (Notion + Google Calendar)
	@echo -e "$(CYAN)🔄 Full synchronization in progress...$(RESET)"
	@$(PY) main.py sync
	@$(PY) main.py calendar import
	@echo -e "$(GREEN)✓ All sources synchronized.$(RESET)"

.PHONY: chat
chat: redis-ready ## Enter interactive chat mode with Orchestrator
	@$(PY) main.py chat

# -----------------------------------------------------------------------------
# QUALITY & SECURITY (NΞØ COMPLIANCE)
# -----------------------------------------------------------------------------

.PHONY: check
check: lint test ## Run linting and tests (CI local)
	@echo -e "$(GREEN)✓ All checks passed.$(RESET)"

.PHONY: lint
lint: ## Check code style with ruff
	@echo -e "$(CYAN)Linting with Ruff...$(RESET)"
	@$(RUFF) check . --fix || true

.PHONY: fmt
fmt: ## Format code with ruff
	@echo -e "$(CYAN)Formatting with Ruff...$(RESET)"
	@$(RUFF) format .

.PHONY: test
test: ## Run pytest suite
	@echo -e "$(CYAN)Running tests...$(RESET)"
	@$(PYTEST) tests/ -v --tb=short

.PHONY: security
security: ## Check for vulnerabilities in dependencies
	@echo -e "$(CYAN)Auditing dependencies...$(RESET)"
	@$(PIP_AUDIT) || (echo -e "$(RED)⚠ Vulnerabilities found!$(RESET)"; exit 1)
	@echo -e "$(GREEN)✓ Security audit passed.$(RESET)"

# -----------------------------------------------------------------------------
# GIT PROTOCOL (NΞØ SECURE COMMIT)
# -----------------------------------------------------------------------------

.PHONY: commit
commit: check security ## [NΞØ] Secure commit & push flow
	@echo -e "\n$(BOLD)$(CYAN)--- NΞØ SECURE COMMIT FLOW ---$(RESET)"
	@git status -s
	@echo -e "\n$(YELLOW)Conventional Commit Types: feat, fix, docs, style, refactor, test, chore$(RESET)"
	@read -p "Commit message: " msg; \
	if [ -z "$$msg" ]; then echo -e "$(RED)Aborted: Message required.$(RESET)"; exit 1; fi; \
	git add . && \
	git commit -m "$$msg" && \
	git push origin $$(git branch --show-current) && \
	echo -e "$(GREEN)✓ Securely committed and pushed to $$(git branch --show-current).$(RESET)"

# -----------------------------------------------------------------------------
# REDIS MANAGEMENT
# -----------------------------------------------------------------------------

REDIS_CONTAINER := multiagentes-redis
REDIS_PORT      := 6379

.PHONY: redis-ready
redis-ready: ## Ensure Redis is running (Docker or Brew)
	@if redis-cli ping > /dev/null 2>&1; then exit 0; fi; \
	if docker ps | grep -q $(REDIS_CONTAINER); then exit 0; fi; \
	echo -e "$(YELLOW)Starting Redis...$(RESET)"; \
	docker run -d --rm --name $(REDIS_CONTAINER) -p $(REDIS_PORT):6379 redis:7-alpine > /dev/null 2>&1 || \
	brew services start redis > /dev/null 2>&1 || \
	(echo -e "$(RED)✗ Failed to start Redis.$(RESET)"; exit 1)
	@sleep 1

.PHONY: redis-stop
redis-stop: ## Stop Redis services
	@docker stop $(REDIS_CONTAINER) 2>/dev/null || true
	@brew services stop redis 2>/dev/null || true
	@echo -e "$(YELLOW)✓ Redis stopped.$(RESET)"

.PHONY: redis-cli
redis-cli: ## Open Redis CLI
	@redis-cli || docker exec -it $(REDIS_CONTAINER) redis-cli

# -----------------------------------------------------------------------------
# INFRA & CLEANUP
# -----------------------------------------------------------------------------

.PHONY: venv
venv: ## Create virtual environment
	@test -d $(VENV) || $(PYTHON) -m venv $(VENV)
	@echo -e "$(GREEN)✓ Virtualenv created.$(RESET)"

.PHONY: install
install: venv ## Install requirements + security tools
	@$(PIP) install --upgrade pip -q
	@$(PIP) install -r requirements.txt -q
	@$(PIP) install ruff pytest pip-audit -q
	@echo -e "$(GREEN)✓ Dependencies installed.$(RESET)"

.PHONY: env-init
env-init: ## Initialize .env from example
	@test -f .env || (cp .env.example .env && echo -e "$(YELLOW)✓ .env initialized.$(RESET)")

.PHONY: clean
clean: ## Remove caches and temporary files
	@find . -type d -name "__pycache__" -exec rm -rf {} +
	@rm -rf .ruff_cache .pytest_cache .coverage htmlcov
	@echo -e "$(YELLOW)✓ Cleanup complete.$(RESET)"

.PHONY: shell
shell: ## Drop into an interactive iPython shell
	@$(PIP) install ipython -q
	@$(BIN)/ipython
