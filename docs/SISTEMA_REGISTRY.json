      "calendar_sync": "agents/calendar_sync.py"
    }
  },
  "cli_entrypoints": [
    {
      "command": "sync",
      "file": "main.py",
      "connects_to": ["notion_sync"]
    },
    {
      "command": "focus",
      "file": "main.py",
      "connects_to": ["focus_guard", "scheduler", "redis"]
    },
    {
      "command": "add-task",
      "file": "main.py",
      "connects_to": ["redis", "notion_sync", "scheduler"]
    },
    {
      "command": "ecosistema",
      "file": "main.py",
      "connects_to": ["ecosystem_monitor", "redis"]
    }
  ],
